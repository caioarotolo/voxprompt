# VoxPrompt — copie para .env e preencha. NÃO comite o .env (já está no .gitignore).
# Vars exportadas no shell têm precedência sobre este arquivo.

# Backend de STT: local | openai
STT_BACKEND=openai

# --- OpenAI (exigido quando STT_BACKEND=openai) ---
OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-transcribe

# --- STT local (servidor Parakeet OpenAI-compatible) ---
LOCAL_STT_URL=http://localhost:8000/v1
LOCAL_STT_MODEL=parakeet-tdt-0.6b-v3

# Template inicial: spec | commit | prompt | raw
VOXPROMPT_TEMPLATE=spec

# Binário do Claude Code
CLAUDE_BIN=claude

# Modelo do `claude -p` na estruturação (alias: sonnet | opus | haiku).
# Vazio = herda o default do seu Claude Code. 'sonnet' é mais barato/rápido p/ esta tarefa.
CLAUDE_MODEL=sonnet

# ATENÇÃO: NÃO defina ANTHROPIC_API_KEY aqui.
# Se ela existir no ambiente, `claude -p` pode cobrar via API (billing) em vez de
# usar sua assinatura — e a TUI mostra um alerta vermelho. Deixe-a fora do .env.
